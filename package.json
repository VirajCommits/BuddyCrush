{
  "name": "my-nextjs-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:flask": "bash scripts/dev-flask.sh",
    "dev:all": "concurrently -k -n web,api -c cyan,magenta \"npm run dev\" \"npm run dev:flask\"",
    "setup:python": "python3 -m venv .venv && ./.venv/bin/pip install -r requirements.txt",
    "setup:env": "node -e \"const fs=require('fs');const p='.env';if(!fs.existsSync('env.example')){console.error('env.example not found');process.exit(1);}if(fs.existsSync(p)){console.log('.env already exists');process.exit(0);}fs.copyFileSync('env.example',p);console.log('Created .env from env.example — add Google OAuth values.');\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "export": "next export"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.65.1",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "canvas-confetti": "^1.9.3",
    "dotenv": "^16.4.7",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.3",
    "next": "^15.5.14",
    "next-auth": "^4.24.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.4.0",
    "react-router-dom": "^6.28.1",
    "serve": "^14.2.4",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "eslint": "^9",
    "eslint-config-next": "15.1.3",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "engines": {
    "node": "24.x"
  }
}
