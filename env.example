# Copy to ".env" in this folder (same directory as package.json), OR put the same
# variables in backend/.env. Restart Flask after changes.

FLASK_SECRET_KEY=change-me-to-a-random-string

# Used after Google login redirect (local dev with Next proxy)
FRONTEND_URL=http://localhost:3000

# Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID (Web application)
# Authorized redirect URI must include exactly:
#   http://localhost:3000/api/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Optional (defaults match Google’s public OAuth endpoints)
# GOOGLE_AUTH_URI=https://accounts.google.com/o/oauth2/v2/auth
# GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
